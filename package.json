{
  "name": "hireflow",
  "version": "1.0.0",
  "scripts": {
  "start:gateway": "nodemon --cwd gateway src/server.js",
  "start:user": "nodemon --cwd services/user-service src/server.js",
  "start:application": "nodemon --cwd services/application-service src/server.js",
  "start:analytics": "nodemon --cwd services/analytics-service src/server.js",
  "dev": "concurrently --names \"GATEWAY,USER,APP,ANALYTICS\" --prefix-colors \"blue,green,yellow,magenta\" \"npm run start:gateway\" \"npm run start:user\" \"npm run start:application\" \"npm run start:analytics\""
}
,
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}
